# Режим работы: realtime | historical | both
MODE=realtime

# Количество воркеров для исторической загрузки
WORKER_COUNT=5

# true  → реальные транзакции через GetBlockTransactionsV2 (точно, но медленнее)
# false → только количество шардов (быстро, для historical bulk-загрузки)
DETAILED=true

# ==================== Kafka ====================

# Включить/выключить публикацию в Kafka
KAFKA_ENABLED=true

# Адреса брокеров (через запятую)
KAFKA_BROKERS=localhost:9092

# Топик для сырых метрик блоков
KAFKA_TOPIC_BLOCKS=ton.blocks

# Топик для агрегированных метрик
KAFKA_TOPIC_METRICS=ton.metrics

# Consumer Group ID
KAFKA_GROUP_ID=ton-scrapper
