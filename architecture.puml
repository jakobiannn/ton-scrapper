rectangle "–ú–æ–¥—É–ª—å —Ö—Ä–∞–Ω–µ–Ω–∏—è" as L3 #FFF7ED {
  card "PostgreSQL + TimescaleDB\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nTime-series | ~10x compression\nAuto partitioning" as DB #FFEDD5
}

rectangle "–ú–æ–¥—É–ª—å –∞–Ω–∞–ª–∏–∑–∞" as L4 #FDF2F8 {
  card "Baseline\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nZ-score\nCUSUM" as BL #FCE7F3
  card "ML Models\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nIsolation Forest\nAutoencoder" as ML #FCE7F3
